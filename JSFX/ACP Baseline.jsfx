desc:ACP Studio - Baseline DSP Runtime

options:gmem=ACP_STUDIO

//======================================================================
// ACP Studio
// Baseline DSP Runtime
//
// Specification:
//   BT-001 Baseline DSP
//======================================================================

@init

//---------------------------------------------------------------------
// Shared Memory Registers
//---------------------------------------------------------------------
REG_COMMAND         = 0;
REG_STATE           = 1;
REG_HEARTBEAT       = 2;
REG_SAMPLE_COUNTER  = 3;

//---------------------------------------------------------------------
// Runtime Commands
//---------------------------------------------------------------------
CMD_IDLE            = 0;
CMD_RESET           = 1;
CMD_START           = 2;
CMD_STOP            = 3;

//---------------------------------------------------------------------
// Runtime States
//---------------------------------------------------------------------

STATE_IDLE          = 0;
STATE_RUNNING       = 1;

//---------------------------------------------------------------------
// Runtime Update
//---------------------------------------------------------------------

runtime_state  = STATE_IDLE;
heartbeat      = 0;
sample_counter = 0;

@slider

@block

@sample

//---------------------------------------------------------------------
// Audio Pass-Through
//---------------------------------------------------------------------

// Baseline Runtime does not process audio.
spl0 = spl0;
spl1 = spl1;

//---------------------------------------------------------------------
// Read Runtime Command
//---------------------------------------------------------------------

command = gmem[REG_COMMAND];

//---------------------------------------------------------------------
// Runtime Command Decoder
//---------------------------------------------------------------------

command == CMD_RESET ? (
    //-----------------------------------------------------------------
    // Consume Command
    //-----------------------------------------------------------------

    gmem[REG_COMMAND] = CMD_IDLE;

    //-----------------------------------------------------------------
    // Reset Runtime
    //-----------------------------------------------------------------

    runtime_state  = STATE_IDLE;
    heartbeat      = 0;
    sample_counter = 0;
);

command == CMD_START ? (
    //-----------------------------------------------------------------
    // Consume Command
    //-----------------------------------------------------------------

    gmem[REG_COMMAND] = CMD_IDLE;

    //-----------------------------------------------------------------
    // Start Runtime
    //-----------------------------------------------------------------

    runtime_state = STATE_RUNNING;
);

command == CMD_STOP ? (
    //-----------------------------------------------------------------
    // Consume Command
    //-----------------------------------------------------------------

    gmem[REG_COMMAND] = CMD_IDLE;

    //-----------------------------------------------------------------
    // Stop Runtime
    //-----------------------------------------------------------------

    runtime_state = STATE_IDLE;
);

//---------------------------------------------------------------------
// Runtime
//---------------------------------------------------------------------

runtime_state == STATE_RUNNING ? (
    heartbeat += 1;
    sample_counter += 1;
);

//---------------------------------------------------------------------
// Processing
//---------------------------------------------------------------------

// No DSP processing in BT-001.

//---------------------------------------------------------------------
// Publish Runtime State
//---------------------------------------------------------------------

gmem[REG_STATE]          = runtime_state;
gmem[REG_HEARTBEAT]      = heartbeat;
gmem[REG_SAMPLE_COUNTER] = sample_counter;