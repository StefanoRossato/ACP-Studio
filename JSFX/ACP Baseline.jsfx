desc:ACP Baseline
desc:ACP Studio - Baseline DSP Runtime

options:gmem=ACP_STUDIO

//======================================================================
// ACP Studio
// Baseline DSP Runtime
//
// Specification:
//   BT-001 Baseline DSP
//======================================================================

@init

//---------------------------------------------------------------------
// Shared Memory Registers
//---------------------------------------------------------------------

REG_COMMAND        = 0;
REG_STATE          = 1;
REG_HEARTBEAT      = 2;
REG_SAMPLE_COUNTER = 3;

//---------------------------------------------------------------------
// Runtime States
//---------------------------------------------------------------------

STATE_IDLE         = 0;
STATE_RUNNING      = 1;

//---------------------------------------------------------------------
// Runtime
//---------------------------------------------------------------------

runtime_state  = STATE_IDLE;
heartbeat      = 0;
sample_counter = 0;

@slider

@block

@sample

//---------------------------------------------------------------------
// Audio Pass-Through
//---------------------------------------------------------------------

// Baseline Runtime does not process audio.
spl0 = spl0;
spl1 = spl1;

//---------------------------------------------------------------------
// Read
//---------------------------------------------------------------------

command = gmem[REG_COMMAND];

//---------------------------------------------------------------------
// Runtime
//---------------------------------------------------------------------

runtime_state != STATE_RUNNING ?
(
    runtime_state = STATE_RUNNING;
);

heartbeat += 1;
sample_counter += 1;

//---------------------------------------------------------------------
// Processing
//---------------------------------------------------------------------

// No DSP processing in BT-001.

//---------------------------------------------------------------------
// Write
//---------------------------------------------------------------------

gmem[REG_STATE]          = runtime_state;
gmem[REG_HEARTBEAT]      = heartbeat;
gmem[REG_SAMPLE_COUNTER] = sample_counter;