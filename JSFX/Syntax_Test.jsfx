desc:Syntax Test
options:gmem=ACP_STUDIO

@init

//---------------------------------------------------------------------
// Shared Memory Registers
//---------------------------------------------------------------------
REG_COMMAND         = 0;
REG_STATE           = 1;
REG_HEARTBEAT       = 2;
REG_SAMPLE_COUNTER  = 3;

//---------------------------------------------------------------------
// Runtime Commands
//---------------------------------------------------------------------
CMD_IDLE            = 0;
CMD_RESET           = 1;
CMD_START           = 2;
CMD_STOP            = 3;

//---------------------------------------------------------------------
// Runtime States
//---------------------------------------------------------------------

STATE_IDLE          = 0;
STATE_RUNNING       = 1;

//---------------------------------------------------------------------
// Runtime Variables
//---------------------------------------------------------------------

runtime_state  = STATE_IDLE;
heartbeat      = 0;
sample_counter = 0;



@sample

CMD_IDLE = 0;
runtime_command = gmem[REG_COMMAND];

runtime_command ? (
);

//---------------------------------------------------------------------
// Runtime
//---------------------------------------------------------------------

runtime_state != STATE_RUNNING ?
(
    runtime_state = STATE_RUNNING;
);

heartbeat += 1;
sample_counter += 1;

//---------------------------------------------------------------------
// Publish Runtime State
//---------------------------------------------------------------------

gmem[REG_STATE]          = runtime_state;
gmem[REG_HEARTBEAT]      = heartbeat;
gmem[REG_SAMPLE_COUNTER] = sample_counter;