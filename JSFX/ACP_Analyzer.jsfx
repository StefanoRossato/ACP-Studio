desc:ACP Analyzer
options:gmem=ACP_STUDIO

//--------------------------------------------------
// State
//--------------------------------------------------

@init

peakMax = 0;

//--------------------------------------------------
// Audio Processing
//--------------------------------------------------

@sample

// Controllo reset (lo aggiungeremo nella prossima milestone)

samplePeak = max(abs(spl0), abs(spl1));

peakMax = max(peakMax, samplePeak);

gmem[0] = peakMax;

// Pass audio unchanged

spl0 = spl0;
spl1 = spl1;