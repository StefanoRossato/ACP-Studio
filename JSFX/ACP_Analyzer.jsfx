//--------------------------------------------------
// ACP Studio v0.1
// Baseline 0.1.6
//--------------------------------------------------

desc:ACP Analyzer
options:gmem=ACP_STUDIO

//--------------------------------------------------
// GMEM Layout
//--------------------------------------------------

// 0   Peak Linear
// 1   RMS Average
// 2   RMS Maximum
//100  Command

//--------------------------------------------------
// State
//--------------------------------------------------

@init

peakMax = 0;

//--------------------------------------------------
// Processing
//--------------------------------------------------

@sample

samplePeak = max(abs(spl0), abs(spl1));

peakMax = max(
    peakMax,
    samplePeak
);

//--------------------------------------------------
// Output
//--------------------------------------------------

gmem[0] = peakMax;

// Pass audio unchanged

spl0 = spl0;
spl1 = spl1;