//--------------------------------------------------
// ACP Studio v0.1
// ACP_Analyzer.jsfx
// CF-001.2
//--------------------------------------------------

desc:ACP Analyzer
options:gmem=ACP_STUDIO

//--------------------------------------------------
// Registers (AnalyzerProtocol v1)
//--------------------------------------------------

REG_COMMAND     = 0;
REG_STATE       = 1;

REG_RMS         = 2;
REG_PEAK        = 3;
REG_LINEARITY   = 4;
REG_SAMPLES     = 5;

//--------------------------------------------------
// Commands (Lua -> JSFX)
//--------------------------------------------------

CMD_IDLE        = 0;
CMD_START       = 1;
CMD_RESET       = 2;

//--------------------------------------------------
// States (JSFX -> Lua)
//--------------------------------------------------

STATE_IDLE        = 0;
STATE_MEASURING   = 1;
STATE_COMPLETED   = 2;
STATE_ERROR       = 3;

//--------------------------------------------------
// Internal State
//--------------------------------------------------

@init


isMeasuring = 0;

gmem[REG_STATE] = 99;

// Initialize protocol

gmem[REG_STATE]      = STATE_IDLE;
gmem[REG_RMS]        = 0;
gmem[REG_PEAK]       = 0;
gmem[REG_LINEARITY]  = 0;
gmem[REG_SAMPLES]    = 0;

//--------------------------------------------------
// Processing
//--------------------------------------------------

@sample

command = gmem[REG_COMMAND];

gmem[10] = command;
gmem[REG_STATE] = command;
//--------------------------------------------------
// Pass audio unchanged
//--------------------------------------------------

spl0 = spl0;
spl1 = spl1;